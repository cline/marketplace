{
  "$schema": "../../../schemas/mcp.schema.json",
  "id": "cloudinary-mediaflows",
  "type": "mcp",
  "name": "Cloudinary Mediaflows",
  "tagline": "Connect Cline to Cloudinary Mediaflows",
  "description": "Connect Cline to Cloudinary Mediaflows through this MCP server.",
  "author": {
    "name": "Cloudinary"
  },
  "tags": [
    "data"
  ],
  "verified": false,
  "featured": false,
  "install": {
    "args": [
      "cloudinary-mediaflows",
      "--transport",
      "http",
      "https://mediaflows.mcp.cloudinary.com/v2/mcp",
      "--header",
      "cld-cloud-name: cloud_name",
      "--header",
      "cld-api-key: api_key",
      "--header",
      "cld-secret: api_secret"
    ]
  },
  "homepage": "https://cloudinary.com",
  "repo": "https://github.com/cloudinary-devs/cloudinary-plugin",
  "license": "MIT"
}
